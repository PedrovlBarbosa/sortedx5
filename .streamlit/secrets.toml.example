# Copie este arquivo para secrets.toml e preencha com seus dados do Supabase.
# Nunca commite o secrets.toml real — ele já está no .gitignore.

[app]
# "local" usa SQLite (arquivo sortedx5_local.db)
# "supabase" usa o banco remoto do Supabase
data_mode = "local"

[supabase]
url = "https://SEU-PROJETO.supabase.co"
key = "sua-service-role-key-aqui"
